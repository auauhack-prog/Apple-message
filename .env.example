# ============================================
# 苹果短信自动化 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# 腾讯云API密钥（必填）
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here

# 用户手机号（可选，默认 13800138000）
USER_PHONE=13800138000

# 短信内容（可选，默认 "测试消息"）
SMS_CONTENT=测试消息

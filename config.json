{
  "name": "苹果apple短信群发工具",
  "version": "1.32.0",
  "description": "基于LangGraph构建的智能批量短信引擎，利用Mac序列号机群模拟手机发送短信",
  "demo_url": "https://skill.600.im",
  "contact": "定制Skill & 产品升级沟通: https://skill.600.im",
  "features": 36,
  "env_variables": [
    {"key": "TENCENT_SECRET_ID", "description": "腾讯云API SecretId", "required": true},
    {"key": "TENCENT_SECRET_KEY", "description": "腾讯云API SecretKey", "required": true},
    {"key": "USER_PHONE", "description": "用户手机号", "required": false, "default": "13800138000"},
    {"key": "SMS_CONTENT", "description": "短信内容", "required": false, "default": "测试消息"}
  ]
}
